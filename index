<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Materi 1 - Kotak</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #f8f9fa;
        }

        .header {
            background-color: #0066ff;
            color: white;
            padding: 15px 20px;
        }

        .back-btn {
            display: inline-block;
            background-color: white;
            color: #0066ff;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        h1 {
            font-size: 24px;
            margin-bottom: 20px;
        }

        .content {
            background-color: white;
            margin: 0 20px;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .box {
            width: 150px;
            height: 150px;
            background-color: #0066ff;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="#" class="back-btn">← Kembali</a>
        <h1>Materi 1 - Kotak</h1>
    </div>

    <div class="content">
        <div class="box">Halo</div>
    </div>
</body>
</html>
